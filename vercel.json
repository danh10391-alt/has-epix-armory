{
  "functions": {
    "api/character.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/character", "destination": "/api/character" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
